UIWidget
  id: background
  anchors.fill: parent
  focusable: false
  image-source: /images/UI_REWORK/background
  image-smooth: true
  image-fixed-ratio: true
  margin-top: 1

  UILabel
    id: clientVersionLabel
    image-source: ~
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    text-align: center
    text-auto-resize: true
    font: window
