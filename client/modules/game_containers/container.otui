InboxHistoryItem < UIWidget
  id: InboxHistoryItem
  size: 494 33
  Item
    id: item
    virtual: true
    size: 32 32
    anchors.top: parent.top
    anchors.left: parent.left
    margin-left: 3
  UIItem
    id: itemBall
    virtual: true
    size: 32 32
    anchors.top: parent.top
    anchors.left: parent.left
    margin-left: 3
  UIItem
    id: pokemonItem
    virtual: true
    size: 32 32
    anchors.top: itemBall.top
    anchors.left: itemBall.left
  UIItem
    id: pokeball
    virtual: true
    size: 23 23
    anchors.top: itemBall.top
    anchors.right: itemBall.right
    margin-top: -4
    margin-right: -6
  UIItem
    id: pokeballShiny
    virtual: true
    size: 32 32
    anchors.top: itemBall.top
    anchors.right: itemBall.right
  UIWidget
    id: labelLevel
    font: sono_medium_10
    text-auto-resize: true
    text-align: left
    text-wrap: true
    color: #ffffff
    anchors.left: itemBall.left
    anchors.top: itemBall.top
    margin-top: 1

  UIWidget
    id: nameWidget
    size: 118 33
    phantom: true
    anchors.top: parent.top
    anchors.left: item.right
    margin-left: 13
    UIWidget
      id: label
      !text: tr('Tournament Token')
      font: sono_medium_12
      text-vertical-auto-resize: true
      text-align: center
      text-wrap: true
      color: #ffffff
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
  UIWidget
    id: byWidget
    size: 131 33
    phantom: true
    anchors.top: parent.top
    anchors.left: nameWidget.right
    margin-left: 2
    UIWidget
      id: label
      !text: tr('SYSTEM')
      font: sono_medium_12
      text-vertical-auto-resize: true
      text-align: center
      text-wrap: true
      color: #ffffff
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
  UIWidget
    id: dateWidget
    size: 96 33
    phantom: true
    anchors.top: parent.top
    anchors.left: byWidget.right
    margin-left: 2
    UIWidget
      id: label
      !text: tr('2023-04-03 21:19:59')
      font: sono_medium_12
      text-vertical-auto-resize: true
      text-align: center
      text-wrap: true
      color: #b7b7b7
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.verticalCenter: parent.verticalCenter
  UIWidget
    id: actionWidget
    size: 85 33
    phantom: true
    anchors.top: parent.top
    anchors.left: dateWidget.right
    margin-left: 2
    UIWidget
      id: depotButton
      size: 52 20
      phantom: true
      image-source: /images/ui/container/button_more_off
      anchors.verticalCenter: parent.verticalCenter
      anchors.horizontalCenter: parent.horizontalCenter
      image-color: #b9b9b9
      change-cursor-image: true
      cursor: pointer
      $hover:
        image-color: #ffffff
      $pressed:
        image-color: #8f8f8f
      UIWidget
        id: label
        !text: tr('More')
        font: sono_medium_12
        text-align: center
        color: #ffffff
        phantom: true
        anchors.horizontalCenter: parent.horizontalCenter
        anchors.verticalCenter: parent.verticalCenter


InboxHistoryPanel < GamePanel
  id: InboxHistoryPanel
  size: 509 229
  anchors.horizontalCenter: parent.horizontalCenter
  anchors.bottom: parent.bottom
  margin-bottom: 10
  ScrollablePanel
    id: panelList
    anchors.fill: parent
    margin-left: 16
    margin-right: 18
    margin-top: 50
    margin-bottom: 3
    vertical-scrollbar: ScrollBar
    layout:
      type: grid
      cell-size: 494 33
      cell-spacing: 10
      flow: true
  VerticalScrollBar
    id: ScrollBar
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    step: 25
    margin-top: 25
    margin-bottom: 5
    pixels-scroll: true
  UIWidget
    id: icon_list
    image-auto-resize: true
    anchors.top: parent.top
    anchors.left: parent.left
  UIWidget
    id: tittle
    !text: tr('Hist�rico de Recebidos')
    color: #ffffff
    margin-top: 15
    text-auto-resize: true
    anchors.left: icon_list.right
    anchors.verticalCenter: icon_list.verticalCenter
    margin-left: 10
  UIWidget
    id: barSelections
    size: 545 18
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: parent.right
    margin-right: 10
    margin-top: 24
    UIWidget
      id: itemLabel
      !text: tr('Item')
      color: #69B2FC
      text-auto-resize: true
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 20
    UIWidget
      id: nameLabel
      !text: tr('Name')
      color: #69B2FC
      text-auto-resize: true
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 111
    UIWidget
      id: byLabel
      !text: tr('By')
      color: #69B2FC
      text-auto-resize: true
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 243
    UIWidget
      id: byLabel
      !text: tr('Date')
      color: #69B2FC
      text-auto-resize: true
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 351
    UIWidget
      id: actionLabel
      !text: tr('Action')
      color: #69B2FC
      text-auto-resize: true
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 435

