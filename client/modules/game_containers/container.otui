LockerContainerWindow < MainWindow
  size: 394 264
  opacity: 0.88

  UIItem
    id: containerItemWidget
    virtual: true
    size: 200 200
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    margin-top: -140

  UIButton
    id: upButton
    anchors.top: parent.top
    anchors.right: parent.right
    margin-right: 3
    size: 20 20
    image-source: /images/ui/miniwindow_buttons
    image-clip: 42 0 14 14

    $hover:
      image-clip: 42 14 14 14

    $pressed:
      image-clip: 42 28 14 14

  Panel
    id: pagePanel
    anchors.left: parent.left
    anchors.right: closeButton.left
    anchors.bottom: parent.bottom
    height: 24
    margin: 2 3 0 3
    background: #00000066
    visible: false

    Label
      id: pageLabel
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 4
      text-auto-resize: true

    PageButton
      id: prevPageButton
      text: <
      margin-top: 3
      margin-left: 3
      anchors.top: parent.top
      anchors.left: parent.left

    PageButton
      id: nextPageButton
      text: >
      margin-top: 3
      margin-right: 3
      anchors.top: parent.top
      anchors.right: parent.right

  ScrollablePanel
    id: contentsPanel
    padding: 5
    anchors.fill: parent
    margin-top: 70
    margin-bottom: 30
    border-width: 2
    border-color: #272727
    background-color: #636363
    vertical-scrollbar: miniwindowScrollBar
    layout:
      type: grid
      cell-size: 34 34
      flow: true

  VerticalScrollBar
    id: miniwindowScrollBar
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    step: 14
    margin-top: 70
    margin-bottom: 30
    pixels-scroll: true

  Button
    id: closeButton
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    text: Close

ContainerWindow < ContainerWindow

DepotWindow < MainWindow
  id: containerWindow
  !text: tr('Pokemon Center Machines')
  image-auto-resize: true

  Label
    id: hotkeyLabel
    !text: '(E)'
    font: sono_bold_14
    color: #057FFA
    text-auto-resize: true
    anchors.left: title.right
    anchors.verticalCenter: icon.verticalCenter
    margin-left: 4
  UIWidget
    id: icon
    size: 27 27
    image-source: /images/ui/container/base_background_icon
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 7
    margin-left: 15
    border: 1 alpha
    UIWidget
      id: image
      size: 27 27
      image-source: /images/topbuttons/depot
      anchors.horizontalCenter: parent.horizontalCenter
      anchors.verticalCenter: parent.verticalCenter

  ScrollablePanel
    id: contentsPanel
    size: 494 263
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 92
    margin-left: 20
    vertical-scrollbar: miniwindowScrollBar
    layout:
      type: grid
      cell-size: 32 32
      flow: true
      cell-spacing: 1

  UIWidget
    id: filterPanel
    size: 32 32
    image-source: /images/ui/container_filter
    image-border-top: 11
    image-border-bottom: 11
    anchors.bottom: contentsPanel.top
    anchors.left: contentsPanel.left
    margin-bottom: 5
    UIScrollArea
      id: buttonsPael
      anchors.fill: parent
      margin-left: 6
      margin-top: 5
      margin-bottom: 5
      margin-right: 2
      auto-focus: first
      layout:
        type: grid
        cell-size: 20 20
        flow: true
        cell-spacing: 5

  GamePanel
    id: containerWindow
    size: 509 229
    anchors.horizontalCenter: parent.horizontalCenter
    anchors.bottom: parent.bottom

  UIWidget
    id: Progress
    size: 14 14
    image-source: /images/ui/container/search
    anchors.left: editSearch.left
    anchors.verticalCenter: editSearch.verticalCenter
    margin-left: 10
  TextEdit
    id: editSearch
    size: 175 26
    image-source: /images/ui/tag/edit_text
    font: sono_medium_12
    placeholder: Pesquisar um item.
    placeholder-align: left
    placeholder-font: sono_medium_12
    max-length: 16
    padding-top: 6
    padding-left: 30
    anchors.bottom: contentsPanel.top
    anchors.right: contentsPanel.right
    margin-bottom: 5
    @onTextChange: |
      local tagName = self:getParent():getChildById('tagName')
      local confirmButton = self:getParent():getChildById('confirmButton')
      tagName:setText(self:getText())
      if #self:getText() >= 4 then
        confirmButton:setPhantom(false)
        confirmButton:setImageColor("#b9b9b9")
      else
        confirmButton:setPhantom(true)
        confirmButton:setImageColor("#8f8f8f")
      end

  VerticalScrollBar
    id: miniwindowScrollBar
    anchors.top: contentsPanel.top
    anchors.bottom: contentsPanel.bottom
    anchors.left: contentsPanel.right
    step: 14
    margin-left: 9
    pixels-scroll: true

  UIButton
    id: closeButton
    size: 14 14
    image-source: /images/ui/container/close_button
    anchors.top: parent.top
    anchors.right: parent.right
    margin-top: 13
    margin-right: 15
    image-color: #cbcbcb
    opacity: 1.0
    change-cursor-image: true
    cursor: pointer
    @onClick: |
      local parentWidget = self:getParent()
      g_effects.fadeOut(parentWidget, 350)
      modules.game_walking.enableWSAD()
      scheduleEvent(function() 
        parentWidget:destroy()
      end, 400)
    $hover:
      opacity: 1.0
      image-color: #ffffff
    $pressed:
      opacity: 0.8
      image-color: #9c9c9c

    UIButton
      id: miniwindowTopBar
      size: 14 14
      visible: false
      image-source: /images/ui/container/close_button
      anchors.top: parent.top
      anchors.right: parent.right
    UIButton
      id: lockButton
      size: 14 14
      visible: false
      image-source: /images/ui/container/close_button
      anchors.top: parent.top
      anchors.right: parent.right
    UIButton
      id: minimizeButton
      size: 14 14
      visible: false
      image-source: /images/ui/container/close_button
      anchors.top: parent.top
      anchors.right: parent.right
    UIButton
      id: bottomResizeBorder
      size: 14 14
      visible: false
      image-source: /images/ui/container/close_button
      anchors.top: parent.top
      anchors.right: parent.right

    Panel
      id: pagePanel
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.top: parent.top
      margin: 1 3 0 3
      background: #00000066
      height: 20
      visible: false
      $on:
        visible: true
      $!on:
        visible: false
      Label
        id: pageLabel
        anchors.top: parent.top
        anchors.horizontalCenter: parent.horizontalCenter
        margin-top: 2
        text-auto-resize: true
      PageButton
        id: prevPageButton
        text: <
        anchors.top: parent.top
        anchors.left: parent.left
      PageButton
        id: nextPageButton
        text: >
        anchors.top: parent.top
        anchors.right: parent.right


