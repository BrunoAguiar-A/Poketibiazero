SlotBarAbilitiesIcon < UIWidget
  size: 12 12
  image-source: /images/game/pokebar/icons
  change-cursor-image: true
  cursor: pointer
  phantom: false

SlotBarTimerBall < UIWidget
  id: timer
  size: 14 14
  image-source: /images/game/pokebar/timer_ball
  image-clip: 18 0 18 18

  $on:
    image-clip: 0 0 18 18

SlotBar < UIWidget
  size: 140 60
  anchors.top: parent.top
  anchors.left: parent.left
  image-source: /images/game/pokebar/slotbar
  image-clip: 0 80 140 60
  draggable: true
  phantom: false
  margin-left: 10
  &dragLeave: 0
  &moveSlot: true

  $!first:
    anchors.top: prev.bottom
    margin-top: 2

  $checked:
    size: 186 80
    image-clip: 0 0 186 80

  $on:
    image-clip: 0 140 140 60

  UIWidget
    id: image
    size: 54 54
    anchors.left: parent.left
    anchors.verticalCenter: parent.verticalCenter
    phantom: true
    opacity: 1
    margin-left: 3
    image-fixed-ratio: true
    image-smooth: true

    $disabled:
      opacity: 0.3

    $checked:
      size: 74 74

  ProgressBar
    id: progress
    size: 160 14
    anchors.top: parent.top
    anchors.left: image.right
    anchors.right: parent.right
    margin: 15 8 0 8
    font: sono_bold_14
    phantom: true

    $disabled:
      background-color: #3A3A3A

    $checked:
      size: 160 18
      margin: 20 8 0 8

  UIButton
    id: keyCombo
    size: 42 14
    anchors.left: prev.left
    anchors.bottom: parent.bottom
    anchors.top: prev.bottom
    margin: 3 1 14 1
    image-color: #D2D2D2
    color: #727272
    font: sono_bold_12

    $on:
      image-color: #242424
      color: #727272

    $checked:
      size: 46 20
      margin: 6 0 20 1

  HorizontalList
    id: abilities
    height: 11
    anchors.right: progress.right
    anchors.verticalCenter: prev.verticalCenter
    margin: 2 2 2 4

    $checked:
      height: 11
      margin: 2 2 2 4

  SlotBarTimerBall
    anchors.right: progress.right
    anchors.bottom: keyCombo.bottom
    margin-right: 2
    visible: false

    $checked:
      size: 18 18

  Panel
    id: elements
    width: 20
    anchors.left: parent.left
    anchors.verticalCenter: parent.verticalCenter
    layout: verticalBox
    &px: 20
    margin: 0 0 0 -8

    $checked:
      width: 24
      &px: 24
      margin: 0 0 0 -10

Panel
  id: panelBar
  size: 199 80
  pos: 10 150
  focusable: false
  &currentMode: 2
  &orientation: 2
  &isEditingMode: false

