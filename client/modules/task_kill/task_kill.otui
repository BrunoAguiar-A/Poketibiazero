TaskAccept < UIWidget
  size: 95 112
  anchors.right: parent.right
  anchors.verticalCenter: parent.verticalCenter
  image-source: images/window_list/new_accept
  margin-right: 25
  change-cursor-image: true
  cursor: pointer

TaskDoneCancel < UIWidget
  id: DoneCancel
  size: 95 112
  anchors.right: parent.right
  anchors.verticalCenter: parent.verticalCenter
  image-source: images/window_list/new_cancel
  margin-right: 25
  change-cursor-image: true
  cursor: pointer

ItemStyle < UIItem
  size: 30 30
  padding: 0
  image-source: ~
  opacity: 0.9
  font: lucida-11px-rounded
  border-color: white
  color: white

  $disabled:
    color: #646464
  $hover:
    opacity: 1.0

TaskButton < Panel
  size: 561 146
  padding-left: 13
  padding: 0
  margin: 3
  phantom: true

  UIWidget
    id: BackgroudType
    size: 561 140
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.left: parent.left 
    anchors.right: parent.right

  UIWidget
    id: SlotOutfit
    size: 71 71
    image-source: images/window_list/slot
    anchors.top: parent.top
    anchors.left: parent.left 
    margin-left: 20
    margin-top: 15

  UIWidget
    id: type1
    size: 14 15
    anchors.top: parent.top
    anchors.left: parent.left 
    margin-left: 25
    margin-top: 17
  UIWidget
    id: type2
    size: 14 15
    anchors.top: parent.top
    anchors.left: parent.left 
    margin-left: 15
    margin-top: 30

  UICreature
    id: CreatureUIPanel
    size: 48 48 
    anchors.top: parent.top  
    anchors.left: parent.left
    margin-left: 32
    margin-top: 25
    old-scaling: true
    
    Panel     
      anchors.top: parent.top  
      anchors.left: parent.left

  UIWidget
    id: NamePoke
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 23
    margin-left: 92
    font: terminus-14px-bold
    color: #d7d7d7
  UIWidget
    id: labelKill
    anchors.top: NamePoke.top
    anchors.left: NamePoke.right  
    text-auto-resize: true
    margin-left: 6
    font: terminus-14px-bold
    color: #d7d7d7
  Label
    id: TimerRefresh
    anchors.top: labelKill.top
    anchors.left: labelKill.right  
    margin-left: 6
    font: terminus-14px-bold
    color: #d7d7d7
  UIWidget
    id: desc
    size: 426 50
    anchors.top: parent.top
    anchors.left: parent.left
    margin-top: 45
    margin-left: 97
    text-align: topLeft
    text-wrap: true
    font: terminus-10px
    color: #d7d7d7
  Label
    id: labelReward
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 29 
    margin-left: 55
  Label
    id: labelPoint
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    margin-bottom: 10
    margin-left: 55
  Label
    id: labelLevel
    anchors.top: desc.top
    anchors.left: parent.left
    margin-top: 23
    margin-left: 40

