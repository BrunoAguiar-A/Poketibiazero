      margin-top: 25
      text-align: left
      font: verdana-11px-rounded
      color: yellow

GameMainWindow
  size: 620 700
  !text: tr('Task Window')

  GamePanel             
    id: panelBanner
    height: 50
    anchors.top: parent.top     
    anchors.right: parent.right
    anchors.left: parent.left
    margin-top: 50

  Label
    id: labelPoints
    size: 120 30
    anchors.top: panelBanner.top
    anchors.left: parent.left
    margin-top: 20
    margin-left: 10

  GamePanel    
    id: panelPTask
    anchors.top: panelBanner.bottom
    anchors.bottom: parent.bottom
    anchors.left: parent.left  
    anchors.right: parent.right
    margin-top: 10	
    phantom: false  

    TextList
      id: panelPTaskList
      anchors.top: panelPTaskListScrollBar.top  
      anchors.left: parent.left      
      anchors.right: panelPTaskListScrollBar.left
      anchors.bottom: panelPTaskListScrollBar.bottom   
      margin-right: 2
      margin-left: 5
      background-color: alpha
      focusable: true   
      vertical-scrollbar: panelPTaskListScrollBar
    
    VerticalScrollBar
      id: panelPTaskListScrollBar
      anchors.top: parent.top
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-right: 0
      step: 60
      pixels-scroll: true

  UIWidget
    id: BackgroundBlack
    size: 991 639
    visible: false
    image-source: images/BackgroundBlack
    opacity: 1
    anchors.top: parent.top
    anchors.left: parent.left
