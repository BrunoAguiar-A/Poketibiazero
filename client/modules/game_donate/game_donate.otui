MainWindow
  id: mainWindow
  size: 300 340
  !text: tr("Doa��es via Pix")

  Label
    id: alertLabel
    !text: tr('Este m�todo est� dispon�vel somente para pessoas no Brasil.')
    height: 35
    text-wrap: true
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.top: parent.top
    margin-top: 35

  Label
    id: userLabel
    !text: tr('Nome')
    anchors.left: parent.left
    anchors.top: alertLabel.bottom
    margin-top: 5

  CreateAccountTextEdit
    id: nameEntryPassword
    text-hidden: false
    anchors.left: userLabel.left
    anchors.right: parent.right
    anchors.top: userLabel.bottom
    margin-top: 5

  CreateAccountTextEdit
    id: nameEntry
    anchors.left: userLabel.left
    anchors.right: parent.right
    anchors.top: userLabel.bottom
    margin-top: 5

  ViewCheckBox
    id: nameCheckBox
    anchors.right: nameEntry.right
    anchors.top: nameEntry.top
    margin-top: 2
    margin-right: 2
    image-color: black
    @onCheckChange: checkBoxCallback('name')

  Label
    id: cpfLabel
    !text: tr('CPF')
    anchors.left: parent.left
    anchors.top: nameEntry.bottom
    margin-top: 10

  CreateAccountTextEdit
    id: cpfEntryPassword
    text-hidden: false
    anchors.left: cpfLabel.left
    anchors.right: parent.right
    anchors.top: cpfLabel.bottom
    margin-top: 5

  CreateAccountTextEdit
    id: cpfEntry
    anchors.left: cpfLabel.left
    anchors.right: parent.right
    anchors.top: cpfLabel.bottom
    margin-top: 5

  ViewCheckBox
    id: cpfCheckBox
    anchors.right: cpfEntry.right
    anchors.top: cpfEntry.top
    margin-top: 2
    margin-right: 2
    image-color: black
    @onCheckChange: checkBoxCallback('cpf')

  Label
    id: valueLabel
    !text: tr('Quantidade')
    anchors.left: parent.left
    anchors.top: cpfEntry.bottom
    margin-top: 10

  CreateAccountTextEdit
    id: valueEntry
    anchors.left: valueLabel.left
    anchors.right: parent.right
    anchors.top: valueLabel.bottom
    margin-top: 5

  ComboBox
    id: valueComboBox
    anchors.left: valueEntry.left
    anchors.right: parent.right
    anchors.top: valueLabel.bottom
    margin-top: 5

  Button
    size: 130 35
    id: submitButton
    !text: tr('Ok')
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    margin-left: 0
    @onClick: submitButtonCallback()

  Button
    size: 130 35
    id: cancelButton
    !text: tr('Cancelar')
    anchors.left: submitButton.right
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    margin-left: 5
    @onClick: closeWindow()